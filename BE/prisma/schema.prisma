// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
}

enum StoreType {
  FOOD
  GROCERY
  PHARMACY
  ELECTRONICS
  FASHION
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  COD    // Cash on Delivery
  STRIPE // Online payment (future)
}

enum UserStatus {
  PENDING    // Mới đăng ký, chờ xác thực email/SĐT
  ACTIVE     // Đang hoạt động bình thường
  INACTIVE   // Tạm dừng hoạt động (người dùng tự đóng)
  BANNED     // Bị quản trị viên khóa do vi phạm
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  password     String?
  fullName     String?
  phone        String?      @unique
  
  // Trạng thái tài khoản
  status       UserStatus   @default(PENDING)
  
  // Xác thực
  isEmailVerified Boolean   @default(false)
  isPhoneVerified Boolean   @default(false)
  
  provider     AuthProvider @default(LOCAL)
  providerId   String?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Quan hệ
  roles              Role[]              @relation("UserRoles")
  tokens             Token[]
  phoneOtps          PhoneOtp[]
  emailVerifications EmailVerification[]
  store              Store?              @relation("StoreOwner")
  orders             Order[]             @relation("CustomerOrders")
  driverDeliveries   Delivery[]          @relation("DriverDeliveries")
  addresses          UserAddress[]
}

model UserAddress {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  label       String   // "Nhà", "Văn phòng"...
  fullAddress String   // Địa chỉ đầy đủ dạng text
  lat         Float?   // Vĩ độ (tùy chọn, dùng cho bản đồ)
  lng         Float?   // Kinh độ
  isDefault   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique // e.g. 'ADMIN', 'CUSTOMER', 'DRIVER'
  description String?

  users User[] @relation("UserRoles")
}

model Token {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Lưu OTP xác thực SĐT — tự xoá sau khi hết hạn hoặc đã dùng
model PhoneOtp {
  id        String   @id @default(uuid())
  phone     String                         // SĐT cần xác thực
  otp       String                         // Mã OTP (đã hash hoặc plain — tuỳ bạn)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts  Int      @default(0)           // Số lần nhập sai (max 5)
  expiresAt DateTime                       // Hết hạn sau 5 phút
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([userId])
}

// Lưu token xác thực email — hết hạn sau 24h
model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique              // UUID random, gửi qua link email
  expiresAt DateTime                      // Hết hạn sau 24h
  createdAt DateTime @default(now())

  @@index([userId])
}

model Store {
  id          String    @id @default(uuid())
  name        String
  type        StoreType @default(FOOD)
  address     String
  description String?
  ownerId     String    @unique
  owner       User      @relation("StoreOwner", fields: [ownerId], references: [id])
  
  products    Product[]
  orders      Order[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]
}

model Product {
  id           String    @id @default(uuid())
  name         String
  description  String?
  price        Float
  stock        Int       @default(0)
  image        String?
  isActive     Boolean   @default(true)

  categoryId   String
  category     Category  @relation(fields: [categoryId], references: [id])
  
  storeId      String
  store        Store     @relation(fields: [storeId], references: [id])
  
  orderItems   OrderItem[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Order {
  id              String        @id @default(uuid())
  totalAmount     Float
  shippingAddress String
  note            String?       // Ghi chú từ customer (tuỳ chọn)
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod @default(COD)
  cancelReason    String?       // Lý do huỷ đơn
  completedAt     DateTime?     // Thời điểm hoàn thành giao hàng
  
  // Khách hàng đặt đơn
  customerId      String
  customer        User          @relation("CustomerOrders", fields: [customerId], references: [id])
  
  // Cửa hàng nhận đơn
  storeId         String
  store           Store         @relation(fields: [storeId], references: [id])
  
  items           OrderItem[]
  delivery        Delivery?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([customerId])
  @@index([storeId])
  @@index([status])
}

model OrderItem {
  id           String  @id @default(uuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  
  quantity     Int
  priceAtOrder Float   // Lưu giá tại thời điểm đặt để tránh thay đổi sau này
}

model Delivery {
  id          String    @id @default(uuid())
  orderId     String    @unique
  order       Order     @relation(fields: [orderId], references: [id])
  
  // Tài xế nhận đơn
  driverId    String?
  driver      User?     @relation("DriverDeliveries", fields: [driverId], references: [id])
  
  // Tọa độ real-time
  currentLat  Float?
  currentLng  Float?

  // Mốc thời gian giao hàng
  pickedUpAt  DateTime? // Khi driver lấy hàng tại store
  deliveredAt DateTime? // Khi giao thành công cho customer
  
  updatedAt   DateTime  @updatedAt

  @@index([driverId])
}